# App identity
APP_NAME=Camp Casey Information App
APP_VERSION=0.1.0

# Timezone / locale
APP_TIMEZONE=Asia/Seoul
DEFAULT_LOCALE=ko

# Defaults
DEFAULT_BUS_STOP_QUERY=CAC
DEFAULT_TRAIN_PROVIDER=bosan
DEFAULT_USD_TO_KRW=1380

# OpenAI (required for chatbot; leave blank to run without AI)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Data root (leave blank to use bundled data/ directory)
# In production set this to a persistent volume path, e.g. /var/data/camp-casey
DATA_ROOT=

# CORS allowed origins (comma-separated, * = allow all)
# Example: https://camp-casey.example.com,https://hovey.example.com
CORS_ALLOWED_ORIGINS=*
